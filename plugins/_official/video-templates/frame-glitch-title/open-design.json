{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "video-template-frame-glitch-title",
  "title": "Glitch Title Frame",
  "title_i18n": {
    "en": "Glitch Title Frame",
    "zh-CN": "故障艺术标题帧"
  },
  "version": "0.1.0",
  "publishedAt": "2026-06-11T09:17:17Z",
  "description": "Digital glitch, chromatic offset, and data-corruption title frame for video transitions or cyberpunk heroes.",
  "description_i18n": {
    "en": "Digital glitch, chromatic offset, and data-corruption title frame for video transitions or cyberpunk heroes.",
    "zh-CN": "数字故障 / 像散偏移 / 数据腐败标题, 适合视频转场 / cyberpunk hero"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "nexu-io",
    "url": "https://github.com/nexu-io",
    "contact": "open-design@nexu.io"
  },
  "homepage": "https://github.com/nexu-io/html-video/tree/main/templates/frame-glitch-title",
  "tags": [
    "video-template",
    "first-party",
    "video",
    "hyperframes",
    "html-video",
    "motion",
    "title",
    "glitch",
    "cyberpunk",
    "rgb-shift",
    "tech",
    "scanline",
    "presentation"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "video",
    "surface": "hyperframes",
    "engine": "hyperframes",
    "preview": {
      "type": "video",
      "poster": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-glitch-title/preview.png",
      "video": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-glitch-title/preview.mp4"
    },
    "useCase": {
      "query": {
        "en": "Use the Glitch Title Frame template to turn my content into a digital-glitch, chromatic-offset, data-corruption title frame for a video transition or cyberpunk hero. Preserve the template's visual signature, use real content and data, and avoid lorem ipsum or placeholder images.",
        "zh-CN": "用「故障艺术标题帧」模板把我的内容做成一段「数字故障 / 像散偏移 / 数据腐败标题, 适合视频转场 / cyberpunk hero」。保持模板的视觉签名，使用真实内容和数据，避免 lorem ipsum 和占位图片。"
      }
    },
    "inputs": [
      {
        "name": "aspect",
        "label": "Aspect ratio",
        "type": "select",
        "options": [
          "16:9"
        ],
        "default": "16:9"
      },
      {
        "name": "format",
        "label": "Output format",
        "type": "select",
        "options": [
          "mp4",
          "webm"
        ],
        "default": "mp4"
      },
      {
        "name": "durationSec",
        "label": "Duration (seconds)",
        "type": "number",
        "default": 15
      }
    ],
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./template.json",
        "./source"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "compose",
          "atoms": [
            "file-write"
          ]
        },
        {
          "id": "render",
          "atoms": [
            "media-video"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write",
      "media:video-generate"
    ]
  }
}
