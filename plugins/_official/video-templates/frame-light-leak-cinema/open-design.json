{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "video-template-frame-light-leak-cinema",
  "title": "Light-Leak Cinematic Frame",
  "title_i18n": {
    "en": "Light-Leak Cinematic Frame",
    "zh-CN": "胶片漏光电影帧"
  },
  "version": "0.1.0",
  "publishedAt": "2026-06-11T09:17:17Z",
  "description": "Film light leaks, grain, 16:9 letterbox, and large serif type for cinematic openings or chapter cards.",
  "description_i18n": {
    "en": "Film light leaks, grain, 16:9 letterbox, and large serif type for cinematic openings or chapter cards.",
    "zh-CN": "胶片漏光 + 颗粒噪点 + 16:9 letterbox + 衬线大字, 电影感开场 / 章节卡"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "nexu-io",
    "url": "https://github.com/nexu-io",
    "contact": "open-design@nexu.io"
  },
  "homepage": "https://github.com/nexu-io/html-video/tree/main/templates/frame-light-leak-cinema",
  "tags": [
    "video-template",
    "first-party",
    "video",
    "hyperframes",
    "html-video",
    "motion",
    "cinema",
    "light-leak",
    "film",
    "35mm",
    "grain",
    "lens-flare",
    "ambient"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "video",
    "surface": "hyperframes",
    "engine": "hyperframes",
    "preview": {
      "type": "video",
      "poster": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-light-leak-cinema/preview.png",
      "video": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-light-leak-cinema/preview.mp4"
    },
    "useCase": {
      "query": {
        "en": "Use the Light-Leak Cinematic Frame template to turn my content into a cinematic opening or chapter card with film light leaks, grain, letterbox framing, and large serif type. Preserve the template's visual signature, use real content and data, and avoid lorem ipsum or placeholder images.",
        "zh-CN": "用「胶片漏光电影帧」模板把我的内容做成一段「胶片漏光 + 颗粒噪点 + 16:9 letterbox + 衬线大字, 电影感开场 / 章节卡」。保持模板的视觉签名，使用真实内容和数据，避免 lorem ipsum 和占位图片。"
      }
    },
    "inputs": [
      {
        "name": "aspect",
        "label": "Aspect ratio",
        "type": "select",
        "options": [
          "16:9"
        ],
        "default": "16:9"
      },
      {
        "name": "format",
        "label": "Output format",
        "type": "select",
        "options": [
          "mp4",
          "webm"
        ],
        "default": "mp4"
      },
      {
        "name": "durationSec",
        "label": "Duration (seconds)",
        "type": "number",
        "default": 15
      }
    ],
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./template.json",
        "./source"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "compose",
          "atoms": [
            "file-write"
          ]
        },
        {
          "id": "render",
          "atoms": [
            "media-video"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write",
      "media:video-generate"
    ]
  }
}
