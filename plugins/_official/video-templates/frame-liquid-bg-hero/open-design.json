{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "video-template-frame-liquid-bg-hero",
  "title": "Liquid Background Hero",
  "title_i18n": {
    "en": "Liquid Background Hero",
    "zh-CN": "流体背景 Hero 帧"
  },
  "version": "0.1.0",
  "description": "WebGL-style fluid displacement background with a quote overlay, suited to video intros, landing heroes, or posters.",
  "description_i18n": {
    "en": "WebGL-style fluid displacement background with a quote overlay, suited to video intros, landing heroes, or posters.",
    "zh-CN": "WebGL 风流体置换背景 + 顶部叠加金句, 适合视频片头 / landing hero / 海报"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "nexu-io",
    "url": "https://github.com/nexu-io",
    "contact": "open-design@nexu.io"
  },
  "homepage": "https://github.com/nexu-io/html-video/tree/main/templates/frame-liquid-bg-hero",
  "tags": [
    "video-template",
    "first-party",
    "video",
    "hyperframes",
    "html-video",
    "motion",
    "hero",
    "liquid",
    "gradient",
    "mesh",
    "editorial",
    "cover",
    "marketing"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "video",
    "surface": "hyperframes",
    "engine": "hyperframes",
    "preview": {
      "type": "video",
      "poster": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-liquid-bg-hero/preview.png",
      "video": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-liquid-bg-hero/preview.mp4"
    },
    "useCase": {
      "query": {
        "en": "Use the Liquid Background Hero template to turn my content into a WebGL-style fluid displacement background with a quote overlay for a video intro, landing hero, or poster. Preserve the template's visual signature, use real content and data, and avoid lorem ipsum or placeholder images.",
        "zh-CN": "用「流体背景 Hero 帧」模板把我的内容做成一段「WebGL 风流体置换背景 + 顶部叠加金句, 适合视频片头 / landing hero / 海报」。保持模板的视觉签名，使用真实内容和数据，避免 lorem ipsum 和占位图片。"
      }
    },
    "inputs": [
      {
        "name": "aspect",
        "label": "Aspect ratio",
        "type": "select",
        "options": [
          "16:9"
        ],
        "default": "16:9"
      },
      {
        "name": "format",
        "label": "Output format",
        "type": "select",
        "options": [
          "mp4",
          "webm"
        ],
        "default": "mp4"
      },
      {
        "name": "durationSec",
        "label": "Duration (seconds)",
        "type": "number",
        "default": 15
      }
    ],
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./template.json",
        "./source"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "compose",
          "atoms": [
            "file-write"
          ]
        },
        {
          "id": "render",
          "atoms": [
            "media-video"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write",
      "media:video-generate"
    ]
  }
}
