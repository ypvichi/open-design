{
  "$schema": "https://open-design.ai/schemas/plugin.v1.json",
  "specVersion": "1.0.0",
  "name": "video-template-frame-decision-tree",
  "title": "Decision Tree",
  "title_i18n": {
    "en": "Decision Tree",
    "zh-CN": "决策树"
  },
  "version": "0.1.0",
  "publishedAt": "2026-06-11T09:17:17Z",
  "description": "Animated flowchart with branching paths",
  "description_i18n": {
    "en": "Animated flowchart with branching paths",
    "zh-CN": "清爽的决策树 / 流程图动效合成，节点与连线依次绘入，适合讲清判断逻辑与分支流程。"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "heygen-com / Hyperframes",
    "url": "https://github.com/heygen-com/hyperframes"
  },
  "homepage": "https://github.com/nexu-io/html-video/tree/main/templates/frame-decision-tree",
  "tags": [
    "video-template",
    "first-party",
    "video",
    "hyperframes",
    "html-video",
    "motion",
    "explainer",
    "flowchart",
    "decision",
    "branching",
    "diagram"
  ],
  "compat": {
    "agentSkills": [
      {
        "path": "./SKILL.md"
      }
    ]
  },
  "od": {
    "kind": "scenario",
    "taskKind": "new-generation",
    "mode": "video",
    "scenario": "video",
    "surface": "hyperframes",
    "engine": "hyperframes",
    "preview": {
      "type": "video",
      "poster": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-decision-tree/preview.png",
      "video": "https://cdn.jsdelivr.net/gh/nexu-io/open-design@main/plugins/_official/video-templates/frame-decision-tree/preview.mp4"
    },
    "useCase": {
      "query": {
        "en": "Use the Decision Tree HyperFrames template to create a 15s explainer video. Replace the sample copy with real content, preserve the template's motion signature, and render to MP4.",
        "zh-CN": "使用「决策树」HyperFrames 模板创建一段约 15 秒的explainer动效视频。把示例文案替换为真实内容，保留模板的动效签名，并渲染为 MP4。"
      }
    },
    "inputs": [
      {
        "name": "aspect",
        "label": "Aspect ratio",
        "type": "select",
        "options": [
          "16:9"
        ],
        "default": "16:9"
      },
      {
        "name": "format",
        "label": "Output format",
        "type": "select",
        "options": [
          "mp4",
          "webm"
        ],
        "default": "mp4"
      },
      {
        "name": "durationSec",
        "label": "Duration (seconds)",
        "type": "number",
        "default": 15
      }
    ],
    "context": {
      "skills": [
        {
          "path": "./SKILL.md"
        }
      ],
      "assets": [
        "./template.json",
        "./source"
      ]
    },
    "pipeline": {
      "stages": [
        {
          "id": "compose",
          "atoms": [
            "file-write"
          ]
        },
        {
          "id": "render",
          "atoms": [
            "media-video"
          ]
        }
      ]
    },
    "capabilities": [
      "prompt:inject",
      "fs:write",
      "media:video-generate"
    ],
    "attribution": [
      {
        "name": "hyperframes registry/examples/decision-tree",
        "license": "Apache-2.0",
        "author": "heygen-com / Hyperframes",
        "url": "https://github.com/heygen-com/hyperframes/tree/main/registry/examples/decision-tree"
      }
    ]
  }
}
