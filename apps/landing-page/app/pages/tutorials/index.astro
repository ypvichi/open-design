---
/*
 * Tutorials index — `/tutorials/`
 *
 * Editorial gallery of Open Design YouTube tutorials. One card per video.
 * Cards link to `/tutorials/<slug>/` where the video plays inline via a
 * privacy-enhanced `youtube-nocookie.com` iframe.
 *
 * Entries come from the `tutorials` Content Collection defined in
 * `app/content.config.ts`. Sorted by date descending. The category strip
 * mirrors the `/blog/` filter UX so the magazine aesthetic stays uniform.
 */
import { getCollection } from 'astro:content';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import SiteAnalytics from '../../_components/site-analytics.astro';
import HeaderEnhancer from '../../_components/header-enhancer.astro';
import { Header, type HeaderProps } from '../../_components/header';
import LocaleSwitcherScript from '../../_components/locale-switcher-script.astro';
import SeoHead from '../../_components/seo-head.astro';
import SiteFooter from '../../_components/site-footer.astro';
import { getCatalogCounts } from '../../_lib/catalog';
import { getGithubRepoMeta } from '../../_lib/github';
import {
  DEFAULT_LOCALE,
  getHeaderLocaleSwitcher,
  getLandingUiCopy,
  getLocaleDefinition,
  localeFromPath,
  localizedHref,
} from '../../i18n';
import '../../globals.css';
import '../../sub-pages.css';

const locale = localeFromPath(Astro.url.pathname);
const localeDef = getLocaleDefinition(locale);
const ui = getLandingUiCopy(locale);
const href = (path: string) => localizedHref(path, locale);
const tutorials = (await getCollection('tutorials')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const videoTutorials = tutorials.filter((entry) => entry.id !== 'open-design-ai-ppt-tutorial');

const counts = await getCatalogCounts();
const github = await getGithubRepoMeta();
const headerHtml = renderToStaticMarkup(
  createElement<HeaderProps>(Header, {
    counts,
    github,
    brandHref: '/',
    active: 'tutorials',
    locale,
    localeSwitcher: getHeaderLocaleSwitcher(locale, Astro.url.pathname),
  }),
);

const seoTitle = ui.tutorials.seoTitle;
const seoDescription = ui.tutorials.description;

const categoryChips = [
  { label: ui.tutorials.categories.all, value: 'all' },
  { label: ui.tutorials.categories.gettingStarted, value: 'getting-started' },
  { label: ui.tutorials.categories.tutorial, value: 'tutorial' },
  { label: ui.tutorials.categories.demo, value: 'demo' },
  { label: ui.tutorials.categories.review, value: 'review' },
  { label: ui.tutorials.categories.community, value: 'community' },
];

const fmtDate = (d: Date) =>
  d.toLocaleDateString(localeDef.htmlLang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

const fmtDuration = (seconds: number) => {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = seconds % 60;
  if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  return `${m}:${String(s).padStart(2, '0')}`;
};

const categoryValue = (category: string) => category.toLowerCase().replace(/\s+/g, '-');
const localizedCategory = (category: string) => {
  const value = categoryValue(category);
  if (value === 'getting-started') return ui.tutorials.categories.gettingStarted;
  if (value === 'tutorial') return ui.tutorials.categories.tutorial;
  if (value === 'demo') return ui.tutorials.categories.demo;
  if (value === 'review') return ui.tutorials.categories.review;
  if (value === 'community') return ui.tutorials.categories.community;
  return category;
};
const localizedTutorial = (entry: (typeof tutorials)[number]) => {
  if (locale === DEFAULT_LOCALE) {
    return {
      title: entry.data.title,
      summary: entry.data.summary,
      category: entry.data.category,
    };
  }
  return {
    title: ui.tutorials.localizedTitle(entry.data.title, entry.data.author),
    summary: ui.tutorials.localizedSummary(
      entry.data.title,
      entry.data.author,
      localizedCategory(entry.data.category),
    ),
    category: localizedCategory(entry.data.category),
  };
};

const ytThumb = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const tutorialThumb = (entry: (typeof tutorials)[number]) =>
  entry.data.thumbnail ?? (entry.data.youtubeId ? ytThumb(entry.data.youtubeId) : '/tutorials/open-design-ai-ppt-tutorial-cover.webp');
const tutorialCta = (entry: (typeof tutorials)[number]) =>
  entry.data.youtubeId ? ui.tutorials.watchCta : 'Read ->';

const featuredTutorial = videoTutorials[0];
const cardTutorials = videoTutorials.slice(1);
const featuredCopy = featuredTutorial ? localizedTutorial(featuredTutorial) : undefined;
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <SeoHead
      kind='website'
      title={seoTitle}
      description={seoDescription}
      pathname={Astro.url.pathname}
    />
    <SiteAnalytics />
  </head>
  <body>
    <div class='shell'>
      <div class='site-chrome' data-chrome-headroom>
        <Fragment set:html={headerHtml} />
      </div>

      <main class='tut-shell'>
        <section class='tut-masthead'>
          <div class='container'>
            <h1 class='tut-title'>{ui.tutorials.title}</h1>
            <p class='tut-sub'>
              {ui.tutorials.description}
            </p>
          </div>
        </section>

        <section class='tut-written-entry'>
          <div class='container'>
            <a class='tut-written-card' href='/tutorials/open-design-ai-ppt-tutorial/'>
              <span class='tut-written-media'>
                <video
                  src='/tutorials/open-design-ai-ppt-motion-demo.mp4'
                  poster='/tutorials/open-design-ai-ppt-tutorial-cover.webp'
                  autoplay
                  muted
                  loop
                  playsinline
                  preload='metadata'
                  aria-label='Open Design AI PPT tutorial preview'
                />
              </span>
              <span class='tut-written-copy'>
                <span class='tut-written-label'>Written workshop</span>
                <strong>Create an AI-powered PPT with Open Design</strong>
                <span>
                  A copy-ready text tutorial for turning raw notes into an editable deck, then
                  refining it with assets, charts, motion, comments, and final QA.
                </span>
              </span>
              <span class='tut-written-cta'>Read tutorial -></span>
            </a>
          </div>
        </section>

        {
          featuredTutorial && featuredCopy && (
            <section
              class='tut-feature'
              data-featured
              data-category={categoryValue(featuredTutorial.data.category)}
            >
              <div class='container'>
                <a
                  class='tut-feature-card'
                  href={href(`/tutorials/${featuredTutorial.id}/`)}
                  style={`--accent-index: 1;`}
                >
                  <span class='tut-feature-thumb'>
                    <img
                      src={tutorialThumb(featuredTutorial)}
                      alt={ui.tutorials.thumbnailAlt(featuredCopy.title)}
                      loading='eager'
                    />
                    {featuredTutorial.data.youtubeId && <span class='tut-play' aria-hidden='true'>▶</span>}
                    {featuredTutorial.data.durationSeconds && (
                      <span class='tut-duration-pill'>
                        {fmtDuration(featuredTutorial.data.durationSeconds)}
                      </span>
                    )}
                  </span>
                  <span class='tut-feature-copy'>
                    <span class='tut-card-cat'>
                      {featuredCopy.category}
                      {featuredTutorial.data.official && (
                        <span class='tut-badge-official'>{ui.tutorials.official}</span>
                      )}
                    </span>
                    <h2 class='tut-feature-title'>{featuredCopy.title}</h2>
                    <p class='tut-feature-summary'>{featuredCopy.summary}</p>
                    <span class='tut-feature-meta'>
                      <span>{featuredTutorial.data.author}</span>
                      <span>·</span>
                      <span>{fmtDate(featuredTutorial.data.date)}</span>
                      <span class='tut-feature-cta'>{tutorialCta(featuredTutorial)}</span>
                    </span>
                  </span>
                </a>
              </div>
            </section>
          )
        }

        <section class='tut-categories'>
          <div class='container'>
            <div class='tut-category-strip' aria-label={ui.tutorials.categoriesLabel}>
              {categoryChips.map((category, index) => (
                <a
                  class:list={['tut-chip', index === 0 && 'is-active']}
                  href={category.value === 'all' ? href('/tutorials/') : href(`/tutorials/?category=${category.value}`)}
                  data-category-filter={category.value}
                >
                  {category.label}
                </a>
              ))}
            </div>
          </div>
        </section>

        <section class='tut-list'>
          <div class='container'>
            {
              tutorials.length === 0 ? (
                <p class='tut-empty'>
                  {ui.tutorials.noEntries}
                  <a href='https://github.com/nexu-io/open-design/issues/new' target='_blank' rel='noreferrer noopener'>
                    {' '}{ui.tutorials.suggestVideo}
                  </a>.
                </p>
              ) : cardTutorials.length === 0 ? null : (
                <ol class='tut-grid'>
                  {cardTutorials.map((entry, idx) => {
                    const copy = localizedTutorial(entry);
                    return (
                      <li
                        class='tut-card'
                        data-tut-item
                        data-category={categoryValue(entry.data.category)}
                      >
                        <a
                          class='tut-card-link'
                          href={href(`/tutorials/${entry.id}/`)}
                          style={`--accent-index: ${idx + 2};`}
                        >
                          <span class='tut-card-thumb'>
                            <img
                              src={tutorialThumb(entry)}
                              alt={ui.tutorials.thumbnailAlt(copy.title)}
                              loading='lazy'
                            />
                            {entry.data.youtubeId && <span class='tut-play' aria-hidden='true'>▶</span>}
                            {entry.data.durationSeconds && (
                              <span class='tut-duration-pill'>
                                {fmtDuration(entry.data.durationSeconds)}
                              </span>
                            )}
                          </span>
                          <span class='tut-card-body'>
                            <span class='tut-card-cat'>
                              {copy.category}
                              {entry.data.official && (
                                <span class='tut-badge-official'>{ui.tutorials.official}</span>
                              )}
                            </span>
                            <h2 class='tut-card-title'>{copy.title}</h2>
                            <p class='tut-card-summary'>{copy.summary}</p>
                            <span class='tut-card-foot'>
                              <span class='tut-card-author'>{entry.data.author}</span>
                              <span class='tut-card-date'>{fmtDate(entry.data.date)}</span>
                              <span class='tut-card-cta'>{tutorialCta(entry)}</span>
                            </span>
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ol>
              )
            }
            <p class='tut-empty is-filter-empty' data-tut-empty hidden>
              {ui.tutorials.noCategory}
            </p>
          </div>
        </section>
      </main>
      <SiteFooter counts={counts} locale={locale} />
    </div>

    <script is:inline>
      (() => {
        const normalize = (value) => (value || 'all').toLowerCase();
        const params = new URLSearchParams(window.location.search);
        const active = normalize(params.get('category'));
        const filters = document.querySelectorAll('[data-category-filter]');
        const items = document.querySelectorAll('[data-tut-item]');
        const featured = document.querySelector('[data-featured]');
        const empty = document.querySelector('[data-tut-empty]');

        let visibleCount = 0;
        for (const item of items) {
          const matches =
            active === 'all' || item.getAttribute('data-category') === active;
          item.hidden = !matches;
          if (matches) visibleCount += 1;
        }
        if (featured) {
          const matches =
            active === 'all' || featured.getAttribute('data-category') === active;
          featured.hidden = !matches;
          if (matches) visibleCount += 1;
        }

        for (const filter of filters) {
          const isActive = filter.getAttribute('data-category-filter') === active;
          filter.classList.toggle('is-active', isActive);
          if (isActive) filter.setAttribute('aria-current', 'page');
          else filter.removeAttribute('aria-current');
        }

        if (empty) empty.hidden = visibleCount !== 0;
      })();
    </script>
    <HeaderEnhancer />
    <LocaleSwitcherScript />

    <style>
      .tut-shell {
        position: relative;
        z-index: 2;
        padding-top: 140px;
        --ui-white: #ffffff;
        --ui-page: #fafafa;
        --ui-surface: #f5f5f5;
        --ui-soft: #f0f0f0;
        --ui-border: #d9d9d9;
        --ui-border-strong: #bfbfbf;
        --ui-muted: #8c8c8c;
        --ui-text-soft: #595959;
        --ui-text: #434343;
        --ui-strong: #262626;
        --ui-brand-bg: #f2ffe6;
        --ui-brand: #63fe13;
        --ui-brand-hover: #83ff3b;
        --ui-brand-text: #218c00;
        --font-size-12: 12px;
        --font-size-13: 13px;
        --font-size-14: 14px;
        --font-size-16: 16px;
        --font-size-18: 18px;
        --font-size-20: 20px;
        --font-size-24: 24px;
        --font-size-28: 28px;
        --font-size-32: 32px;
        --font-size-36: 36px;
        --font-size-48: 48px;
        --font-size-52: 52px;
        --font-size-64: 64px;
        font-family: var(--sans);
        background: var(--ui-page);
      }
      .tut-shell + .sub-footer {
        margin-top: 0;
      }
      .tut-masthead {
        padding: var(--spacing-32) 0 var(--spacing-24);
      }
      .tut-title {
        font-family: var(--sans);
        font-weight: 700;
        letter-spacing: 0;
        font-size: var(--font-size-64);
        line-height: 125%;
        color: var(--ui-strong);
        margin: 0 0 var(--spacing-12);
      }
      .tut-sub {
        font-family: var(--sans);
        font-size: var(--font-size-16);
        line-height: 125%;
        color: var(--ui-text-soft);
        max-width: none;
        margin-bottom: 0;
        white-space: nowrap;
      }
      .tut-written-entry {
        padding: 0 0 var(--spacing-24);
      }
      .tut-written-card {
        display: grid;
        grid-template-columns: minmax(260px, 0.44fr) minmax(0, 1fr) auto;
        gap: var(--spacing-20);
        align-items: center;
        padding: var(--spacing-12) var(--spacing-24) var(--spacing-12) var(--spacing-12);
        border: 1px solid var(--ui-border);
        border-radius: 8px;
        background: var(--ui-white);
        color: var(--ui-strong);
        text-decoration: none;
        transition: border-color 160ms ease, background 160ms ease;
      }
      .tut-written-card:hover {
        border-color: var(--ui-border-strong);
        background: var(--ui-surface);
      }
      .tut-written-media {
        position: relative;
        display: block;
        overflow: hidden;
        aspect-ratio: 16 / 9;
        border: 1px solid var(--ui-border);
        border-radius: 6px;
        background: var(--ui-soft);
      }
      .tut-written-media video {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .tut-written-label {
        font-family: var(--mono);
        font-size: var(--font-size-12);
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ui-brand-text);
      }
      .tut-written-copy {
        display: grid;
        gap: var(--spacing-6);
        min-width: 0;
      }
      .tut-written-copy strong {
        font-family: var(--sans);
        font-size: var(--font-size-20);
        line-height: 125%;
        color: var(--ui-strong);
      }
      .tut-written-copy span {
        font-family: var(--sans);
        font-size: var(--font-size-14);
        line-height: 145%;
        color: var(--ui-text-soft);
      }
      .tut-written-cta {
        font-family: var(--sans);
        font-size: var(--font-size-14);
        font-weight: 700;
        color: var(--ui-brand-text);
        white-space: nowrap;
      }
      .tut-categories {
        padding: var(--spacing-24) 0 0;
      }
      .tut-category-strip {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-10);
        margin: 0 0 var(--spacing-24);
      }
      .tut-chip {
        display: inline-flex;
        align-items: center;
        min-height: 36px;
        padding: var(--spacing-10) var(--spacing-16);
        border: 1px solid var(--ui-border);
        border-radius: 8px;
        font-family: var(--sans);
        font-size: var(--font-size-13);
        line-height: 125%;
        font-weight: 500;
        letter-spacing: 0;
        text-transform: none;
        color: var(--ui-text);
        background: var(--ui-white);
        text-decoration: none;
        transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
      }
      .tut-chip:hover {
        color: var(--ui-strong);
        border-color: var(--ui-border-strong);
        background: var(--ui-surface);
      }
      .tut-chip.is-active {
        color: var(--ui-white);
        background: var(--ui-strong);
        border-color: var(--ui-strong);
      }
      .tut-feature {
        padding: 0 0 var(--spacing-32);
      }
      .tut-feature-card {
        display: grid;
        grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
        min-height: 320px;
        border: 1px solid var(--ui-border);
        border-radius: 8px;
        background: var(--ui-white);
        color: var(--ui-strong);
        text-decoration: none;
        overflow: hidden;
        transition: border-color 160ms ease, background 160ms ease;
      }
      .tut-feature-card:hover {
        border-color: var(--ui-border-strong);
        background: var(--ui-surface);
      }
      .tut-feature-thumb,
      .tut-card-thumb {
        position: relative;
        display: block;
        overflow: hidden;
        background: var(--ui-soft);
        border-bottom: 1px solid var(--ui-border);
      }
      .tut-feature-thumb {
        min-height: 320px;
        height: 320px;
        border-right: 1px solid var(--ui-border);
        border-bottom: 0;
      }
      .tut-card-thumb {
        aspect-ratio: 16 / 9;
        min-height: 0;
      }
      .tut-feature-thumb img,
      .tut-card-thumb img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        filter: saturate(0.92) contrast(1.02);
      }
      .tut-feature-thumb::before,
      .tut-card-thumb::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(38, 38, 38, 0.16));
      }
      .tut-play {
        position: absolute;
        z-index: 2;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: var(--ui-strong);
        color: var(--ui-white);
        font-size: 0;
        line-height: 52px;
        text-align: center;
        transition: transform 180ms ease, background 180ms ease;
      }
      .tut-play::before {
        content: '\f00a';
        font-family: 'Remix Icon';
        font-size: var(--font-size-24);
        font-weight: normal;
        line-height: 52px;
        -webkit-font-smoothing: antialiased;
      }
      .tut-card-link:hover .tut-play,
      .tut-feature-card:hover .tut-play {
        background: var(--ui-brand-text);
        transform: translate(-50%, -50%) scale(1.05);
      }
      .tut-duration-pill {
        position: absolute;
        z-index: 2;
        right: var(--spacing-12);
        bottom: var(--spacing-12);
        padding: var(--spacing-6) var(--spacing-10);
        border-radius: 6px;
        font-family: var(--sans);
        font-size: var(--font-size-12);
        line-height: 125%;
        letter-spacing: 0;
        background: var(--ui-strong);
        color: var(--ui-white);
      }
      .tut-feature-copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: var(--spacing-16);
        padding: var(--spacing-32) var(--spacing-36);
      }
      .tut-feature-title {
        font-family: var(--sans);
        font-size: var(--font-size-36);
        font-weight: 700;
        line-height: 125%;
        letter-spacing: 0;
        color: var(--ui-strong);
      }
      .tut-feature-summary {
        font-family: var(--sans);
        font-size: var(--font-size-16);
        line-height: 125%;
        color: var(--ui-text-soft);
        max-width: 56ch;
      }
      .tut-feature-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--spacing-12);
        padding-top: var(--spacing-16);
        border-top: 1px solid var(--ui-soft);
        font-family: var(--sans);
        font-size: var(--font-size-13);
        line-height: 125%;
        letter-spacing: 0;
        color: var(--ui-muted);
      }
      .tut-feature-cta {
        margin-left: auto;
        font-family: var(--sans);
        font-size: var(--font-size-14);
        line-height: 125%;
        font-weight: 600;
        letter-spacing: 0;
        color: var(--ui-strong);
      }
      .tut-list {
        padding: 0 0 var(--spacing-68);
      }
      .tut-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--spacing-24);
        list-style: none;
      }
      .tut-card {
        min-width: 0;
      }
      .tut-card-link {
        display: flex;
        flex-direction: column;
        min-height: 100%;
        border: 1px solid var(--ui-border);
        border-radius: 8px;
        background: var(--ui-white);
        color: var(--ui-strong);
        text-decoration: none;
        overflow: hidden;
        transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
      }
      .tut-card-link:hover {
        background: var(--ui-surface);
        border-color: var(--ui-border-strong);
        transform: translateY(-2px);
      }
      .tut-card-body {
        display: flex;
        flex: 1;
        flex-direction: column;
        gap: var(--spacing-12);
        padding: var(--spacing-24);
      }
      .tut-card-cat {
        font-family: var(--sans);
        font-size: var(--font-size-12);
        line-height: 125%;
        font-weight: 600;
        letter-spacing: 0;
        text-transform: none;
        color: var(--ui-brand-text);
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-8);
      }
      .tut-card-cat::before {
        content: '';
        width: var(--spacing-18);
        height: 2px;
        background: var(--ui-brand);
      }
      .tut-badge-official {
        margin-left: var(--spacing-4);
        padding: var(--spacing-2) var(--spacing-8);
        border: 1px solid var(--ui-brand);
        border-radius: 6px;
        font-size: var(--font-size-12);
        line-height: 125%;
        letter-spacing: 0;
