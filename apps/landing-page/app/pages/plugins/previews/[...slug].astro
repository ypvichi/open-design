const generatedCommonPreviewCopy = (locale: LandingLocaleCode): PreviewTextMap => {
  if (locale === DEFAULT_LOCALE) return {};
  const terms = PREVIEW_TERMS[locale as Exclude<LandingLocaleCode, 'en'>];
  if (!terms) return {};
  return {
    'How it works': terms.howItWorks,
