---
/*
 * Customer story — Stuart Gardoll  (`/stories/stuart-gardoll/`)
 *
 * Second Open Design customer story. Same bespoke full-bleed band layout as the
 * first (`stories/ikigai-one.astro`): it hand-wires the shared shell — header,
 * footer, SeoHead — the way `blog/[slug].astro` does, then drops in its own
 * `<main class="v4">` band layout + styles.
 *
 * The article body is a self-contained HTML partial injected via `set:html`, so
 * the approved design ships byte-for-byte. Locale variants are generated by
 * `[locale]/stories/stuart-gardoll.astro`, which re-renders this component per
 * locale so the hreflang alternates SeoHead emits all resolve.
 */
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import SiteAnalytics from '../../_components/site-analytics.astro';
import HeaderEnhancer from '../../_components/header-enhancer.astro';
import { Header, type HeaderProps } from '../../_components/header';
import LocaleSwitcherScript from '../../_components/locale-switcher-script.astro';
import SeoHead from '../../_components/seo-head.astro';
import SiteFooter from '../../_components/site-footer.astro';
import { getCatalogCounts } from '../../_lib/catalog';
import { getGithubRepoMeta } from '../../_lib/github';
import {
  getHeaderLocaleSwitcher,
  getLocaleDefinition,
  localeFromPath,
} from '../../i18n';
import '../../globals.css';
import '../../sub-pages.css';
import '../../_partials/stuart-gardoll.css';
import { STORY_BODY, STORY_META } from '../../_partials/stuart-gardoll-i18n';

const locale = localeFromPath(Astro.url.pathname);
const localeDef = getLocaleDefinition(locale);
const counts = await getCatalogCounts();
const github = await getGithubRepoMeta();

// Per-locale article body + page meta come from the generated i18n module.
const storyMain = STORY_BODY[locale] ?? STORY_BODY.en!;
const copy = STORY_META[locale] ?? STORY_META.en!;
const title = copy.title;
const description = copy.description;
const category = 'Customer stories';
// Publish date for the Article schema. Adjust to the actual go-live date.
const datePublished = new Date('2026-07-09');

const fallbackSite = 'https://open-design.ai/';
const origin = Astro.site?.toString() ?? fallbackSite;
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? fallbackSite).toString();
// Dedicated social share card (X/OG/Twitter). Intentionally separate from the
// in-article figures — swapping this does not change any image in the story body.
const ogImage = new URL('/stories/stuart-gardoll-og.jpg', Astro.site ?? fallbackSite).toString();

// Breadcrumb trail (Open Design → Stuart Gardoll). SeoHead emits the Article
// JSON-LD; this adds the SERP breadcrumb.
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Open Design', item: origin },
    { '@type': 'ListItem', position: 2, name: 'Stuart Gardoll', item: pageUrl },
  ],
};

const headerHtml = renderToStaticMarkup(
  createElement<HeaderProps>(Header, {
    counts,
    github,
    brandHref: '/',
    active: 'stories',
    locale,
    localeSwitcher: getHeaderLocaleSwitcher(locale, Astro.url.pathname),
  }),
);
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <SeoHead
      kind='article'
      title={title}
      description={description}
      pathname={Astro.url.pathname}
      datePublished={datePublished}
      category={category}
      image={ogImage}
    />
    <script is:inline type='application/ld+json' set:html={JSON.stringify(breadcrumbJsonLd)} />
    <SiteAnalytics />
  </head>
  <body>
    <div class='shell'>
      <div class='site-chrome' data-chrome-headroom>
        <Fragment set:html={headerHtml} />
      </div>

      <Fragment set:html={storyMain} />

      <SiteFooter counts={counts} locale={locale} />
    </div>

    <HeaderEnhancer />
    <LocaleSwitcherScript />

    <script is:inline>
      (function () {
        var r = document.querySelector('.v4');
        if (!r || !('IntersectionObserver' in window)) return;
        r.classList.add('anim');
        var io = new IntersectionObserver(
          function (es) {
            es.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('inview');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -7% 0px' },
        );
        document.querySelectorAll('.v4 .v4band').forEach(function (b) {
          io.observe(b);
        });
      })();
    </script>
  </body>
</html>
