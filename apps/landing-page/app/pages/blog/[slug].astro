---
/*
 * Blog post — `/blog/[slug]/`
 *
 * Static route generated from the `blog` Content Collection. Renders one
 * post with a narrow editorial body, magazine-style masthead, and a back
 * link to the index. Reuses landing CSS variables and the shared header.
 */
import { getCollection, render } from 'astro:content';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import SiteAnalytics from '../../_components/site-analytics.astro';
import HeaderEnhancer from '../../_components/header-enhancer.astro';
import { Header, type HeaderProps } from '../../_components/header';
import LocaleSwitcherScript from '../../_components/locale-switcher-script.astro';
import SeoHead from '../../_components/seo-head.astro';
import SiteFooter from '../../_components/site-footer.astro';
import BlogToc from '../../_components/blog-toc.astro';
import { getCatalogCounts } from '../../_lib/catalog';
import { getGithubRepoMeta } from '../../_lib/github';
import { getBlogAuthor } from '../../_lib/blog-authors';
import {
  injectTocIntoHtml,
  tocFromHeadings,
  type TocEntry,
} from '../../_lib/blog-toc';
import { getInfoPageCopy } from '../../info-page-i18n';
import {
  explicitLocalizedString,
  localizeBlogPostText,
} from '../../content-i18n';
import {
  getHeaderLocaleSwitcher,
  getLandingUiCopy,
  getLocaleDefinition,
  localeFromPath,
  localizedHref,
} from '../../i18n';
import '../../globals.css';
import '../../sub-pages.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const locale = localeFromPath(Astro.url.pathname);
const localeDef = getLocaleDefinition(locale);
const ui = getLandingUiCopy(locale);
const href = (path: string) => localizedHref(path, locale);
const localizedPostI18n = (post.data as typeof post.data & {
  i18n?: Record<string, Partial<Record<'title' | 'summary' | 'category' | 'bodyHtml', string>>>;
}).i18n?.[locale];
const fallbackPost = localizeBlogPostText({
  id: post.id,
  title: post.data.title,
  summary: post.data.summary,
  category: post.data.category,
  locale,
});
// `localizedPostI18n[field]` is already scoped to the current locale, so a
// plain string there IS the human translation — prefer it directly. (The
// `explicitLocalizedString` map-resolver only accepts a string for the default
// locale, which would otherwise leave hand-written frontmatter translations
// dormant on every non-English page.) Fall back to the locale-map resolver,
// then to the synthetic `localizeBlogPostText` template.
const directLocalized = (field: 'title' | 'summary' | 'category' | 'bodyHtml') => {
  const value = localizedPostI18n?.[field];
  return typeof value === 'string' && value.trim() ? value : undefined;
};
const localizedPostField = (field: 'title' | 'summary' | 'category') => {
  return (
    directLocalized(field) ??
    explicitLocalizedString(
      localizedPostI18n?.[field] as Parameters<typeof explicitLocalizedString>[0],
      locale,
    ) ??
    fallbackPost[field]
  );
};
const localizedBodyHtml =
  directLocalized('bodyHtml') ??
  explicitLocalizedString(
    localizedPostI18n?.bodyHtml as Parameters<typeof explicitLocalizedString>[0],
    locale,
  ) ??
  fallbackPost.bodyHtml;

// A localized bodyHtml can differ in length from the English Markdown; prefer a
// per-locale readingTime when one is set so the estimate matches what the reader
// actually sees, and fall back to the shared English value otherwise.
const localizedReadingTime =
  (localizedPostI18n as { readingTime?: number } | undefined)?.readingTime ??
  post.data.readingTime;

// Build the table of contents. For pre-rendered bodyHtml (rich/localized
// posts) inject heading ids and collect the TOC in one pass; for the Markdown
// `<Content />` path use Astro's already-slugged `headings` array.
let bodyHtmlToRender = localizedBodyHtml;
let toc: TocEntry[];
if (localizedBodyHtml) {
  const injected = injectTocIntoHtml(localizedBodyHtml);
  // Localize root-relative internal links (e.g. related-post `/blog/...`
  // anchors) to the current locale so a non-English reader stays on their
  // locale's routes instead of being dropped back onto the English ones.
  // `localizedHref` leaves external, mailto/tel, and `#` links untouched, and
  // is a no-op for the default locale. Only `<a>` carries `href` in post HTML
  // (`<img>` uses `src`), so matching every `href` attribute is safe.
  bodyHtmlToRender = injected.html.replace(
    /href="([^"]+)"/g,
    (_match, link) => `href="${localizedHref(link, locale)}"`,
  );
  toc = injected.toc;
} else {
  toc = tocFromHeadings(headings);
}
const tocLabel = getInfoPageCopy(locale).common.onThisPage;

// Each post ships a unified cover at `/blog/<slug>-cover.webp` (see the
// `od-site-illustration` skill). Surfaced as a hero banner on the post itself,
// not just on the index card.
const coverSrc = `/blog/${post.id}-cover.webp`;
const socialImageSrc = ((post.data as { socialImage?: string }).socialImage ?? coverSrc).trim();
const coverImage = new URL(socialImageSrc, Astro.site ?? 'https://open-design.ai/').toString();

const DISCORD = 'https://discord.gg/mHAjSMV6gz';
const sourceUrl = `https://github.com/nexu-io/open-design/blob/main/apps/landing-page/app/content/blog/${post.id}.md`;
const category = post.data.category.toLowerCase();
// Optional per-post override: `ctaKind: download-app` in frontmatter points the
// primary CTA at the desktop client download page (/download); Discord stays the
// secondary button. Falls back to the category-based default when unset, so the
// existing posts are unaffected.
const ctaConfig = post.data as {
  ctaKind?: string;
  ctaHref?: string;
  ctaTitle?: string;
  ctaBody?: string;
  ctaLabel?: string;
};
const ctaKind = ctaConfig.ctaKind;
const bottomCta =
  ctaKind === 'event-register'
    ? {
        title: ctaConfig.ctaTitle ?? ui.blog.cta.repoTitle,
        body: ctaConfig.ctaBody ?? ui.blog.cta.repoBody,
        href: ctaConfig.ctaHref ?? 'https://github.com/nexu-io/open-design',
        label: ctaConfig.ctaLabel ?? ui.blog.cta.repoLabel,
        external: true,
      }
    : ctaKind === 'download-app'
    ? {
        title: ui.blog.cta.downloadTitle,
        body: ui.blog.cta.downloadBody,
        href: '/download/',
        label: ui.blog.cta.downloadLabel,
        external: false,
      }
    : category.includes('announcement') || category.includes('product')
    ? {
        title: ui.blog.cta.downloadTitle,
        body: ui.blog.cta.downloadBody,
        href: 'https://github.com/nexu-io/open-design/releases',
        label: ui.blog.cta.downloadLabel,
        external: true,
      }
    : category.includes('guide') || category.includes('use') || category.includes('case')
      ? {
          title: ui.blog.cta.skillsTitle,
          body: ui.blog.cta.skillsBody,
          href: '/skills/',
          label: ui.blog.cta.skillsLabel,
          external: false,
        }
      : {
          title: ui.blog.cta.repoTitle,
          body: ui.blog.cta.repoBody,
          href: 'https://github.com/nexu-io/open-design',
          label: ui.blog.cta.repoLabel,
          external: true,
        };

const counts = await getCatalogCounts();
const github = await getGithubRepoMeta();

const origin = Astro.site?.toString() ?? 'https://open-design.ai/';
const postUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://open-design.ai/').toString();

// BreadcrumbList for the blog post. SeoHead already emits the Article
// JSON-LD via `kind='article'`; the breadcrumb here adds the trail
// (Open Design → Blog → <post title>) so Google can render the post
// with breadcrumb-style URLs in the SERP.
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Open Design', item: origin },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', origin).toString() },
    { '@type': 'ListItem', position: 3, name: localizedPostField('title'), item: postUrl },
  ],
};
const headerHtml = renderToStaticMarkup(
  createElement<HeaderProps>(Header, {
    counts,
    github,
    brandHref: '/',
    active: 'blog',
    locale,
    localeSwitcher: getHeaderLocaleSwitcher(locale, Astro.url.pathname),
  }),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString(localeDef.htmlLang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

// Optional team-persona byline (avatar + name + role). Posts without an
// `author` frontmatter id render no byline, unchanged.
const author = getBlogAuthor((post.data as { author?: string }).author);
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <SeoHead
      kind='article'
      title={localizedPostField('title')}
      description={localizedPostField('summary')}
      pathname={Astro.url.pathname}
      image={coverImage}
      datePublished={post.data.date}
      category={post.data.category}
    />
    <script is:inline type='application/ld+json' set:html={JSON.stringify(breadcrumbJsonLd)} />
    <SiteAnalytics />
  </head>
  <body>
    <div class='shell'>
      <div class='site-chrome' data-chrome-headroom>
        <Fragment set:html={headerHtml} />
      </div>

      <main class='post-shell'>
      <article class='post'>
        <div class='container'>
          <div class='post-grid'>
            <aside class='post-toc-rail'>
              <BlogToc toc={toc} label={tocLabel} />
            </aside>

            <div class='post-main'>
          <div class='post-head'>
            <a class='post-back' href={href('/blog/')}>{ui.blog.backToBlog}</a>

            <h1 class='post-title'>{localizedPostField('title')}</h1>

            <p class='post-summary'>{localizedPostField('summary')}</p>

            <div class='post-meta'>
              <span>{fmtDate(post.data.date)}</span>
              <span>{localizedReadingTime} {ui.blog.minRead}</span>
              <span>{localizedPostField('category')}</span>
            </div>

            {author && (
              <div class='post-author'>
                <img
                  class='post-author-avatar'
                  src={author.avatar}
                  alt={author.name}
                  width='44'
                  height='44'
                  loading='lazy'
                />
                <span class='post-author-text'>
                  <span class='post-author-name'>{author.name}</span>
                  <span class='post-author-role'>{author.role}</span>
                </span>
              </div>
            )}

            <figure class='post-cover'>
              <img
                src={coverSrc}
                alt={localizedPostField('title')}
                width='1536'
                height='1024'
                loading='eager'
              />
            </figure>

            <hr class='post-rule' />
          </div>

          <div class='post-body'>
            {bodyHtmlToRender ? (
              <Fragment set:html={bodyHtmlToRender} />
            ) : (
              <Content />
            )}
          </div>

          <aside class='post-conversion' aria-labelledby='post-conversion-title'>
            <div>
              <span class='label'>{ui.blog.nextStep}</span>
              <h2 id='post-conversion-title'>{bottomCta.title}</h2>
              <p>{bottomCta.body}</p>
            </div>
            <div class='post-conversion-actions'>
              <a
                class='btn btn-primary'
                href={bottomCta.external === false ? href(bottomCta.href) : bottomCta.href}
                target={bottomCta.external === false ? undefined : '_blank'}
                rel={bottomCta.external === false ? undefined : 'noreferrer noopener'}
              >
                {bottomCta.label}
              </a>
              <a class='btn btn-ghost' href={DISCORD} target='_blank' rel='noreferrer noopener'>
                {ui.blog.joinDiscord}
              </a>
            </div>
          </aside>

          <hr class='post-rule' />

          <div class='post-foot'>
            <a class='post-back' href={href('/blog/')}>{ui.blog.backToBlog}</a>
            <a
              class='post-github'
              href={sourceUrl}
              target='_blank'
              rel='noreferrer noopener'
            >
              {ui.blog.viewSource}
            </a>
          </div>
            </div>
          </div>
        </div>
      </article>
      </main>
      <SiteFooter counts={counts} locale={locale} />
    </div>

    <HeaderEnhancer />
    <LocaleSwitcherScript />

    <style>
      .post-shell {
        position: relative;
        z-index: 2;
      }
      .post-shell + .sub-footer {
        margin-top: 0;
      }
      .post {
        /* Clear the absolutely-positioned .site-chrome (~123px tall) so the
         * back-link / title don't slide under the nav. Matches the 140px
         * offset the other sub-pages use. */
        padding: 140px 0 96px;
      }
      /* Default: a single, generous reading column centered on the page. The
       * masthead and body live in the same column (`.post-main`) so they always
       * share the exact same width — no offset, no compression. */
      .post .container {
        max-width: 780px;
      }
      .post-head {
        margin: 0;
      }
      .post-grid {
        display: block;
      }
      .post-main {
        min-width: 0;
      }
      /* Narrow / tablet: the TOC rail folds away; the article keeps full width.
       * It only returns once the viewport is wide enough to host it in the
       * right gutter WITHOUT stealing width from the body (below). */
      .post-toc-rail {
        display: none;
      }
      /* Wide screens: park the sticky TOC in the right gutter. The page widens
       * to make room; the body column stays a fixed 780px measure so it is
       * never squeezed by the rail. */
      @media (min-width: 1140px) {
        .post .container {
          max-width: 1088px;
        }
        .post-grid {
          display: grid;
          grid-template-columns: minmax(0, 780px) 230px;
          gap: 0 78px;
          justify-content: center;
          align-items: start;
        }
        .post-main {
          grid-column: 1;
        }
        .post-toc-rail {
          display: block;
          grid-column: 2;
          grid-row: 1;
          position: sticky;
          top: 140px;
          /* Cap the rail so very long TOCs scroll internally instead of running
           * past the viewport. */
          max-height: calc(100vh - 180px);
          overflow-y: auto;
        }
      }
      /* Anchor jumps land the heading below the sticky site chrome instead of
       * under it — also keeps the scroll-spy offset and the visible heading in
       * agreement. */
      .post-body :global(h2),
      .post-body :global(h3) {
        scroll-margin-top: 124px;
      }
      .post-back {
        display: inline-block;
        font-family: var(--sans);
        font-size: 13px;
        color: var(--ink-mute);
        text-decoration: none;
        margin-bottom: 36px;
        transition: color 160ms ease;
      }
      .post-back:hover {
        color: var(--coral);
      }
      .post-title {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(40px, 5vw, 64px);
        line-height: 1.08;
        letter-spacing: -0.018em;
        color: var(--ink);
        margin: 18px 0 24px;
      }
      .post-summary {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(19px, 1.8vw, 22px);
        line-height: 1.45;
        color: var(--ink-soft);
        max-width: 56ch;
        margin-bottom: 28px;
      }
      .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 10px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        color: var(--ink-faint);
        margin-bottom: 32px;
      }
      .post-meta span + span::before {
        content: '';
        display: inline-block;
        width: 14px;
        height: 1px;
        margin-right: 10px;
        vertical-align: middle;
        background: var(--line);
      }
      .post-author {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 20px;
      }
      .post-author-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--line);
        background: var(--paper-warm);
      }
      .post-author-text {
        display: flex;
        flex-direction: column;
        line-height: 1.3;
      }
      .post-author-name {
        font-weight: 600;
        color: var(--ink);
        font-size: 15px;
      }
      .post-author-role {
        font-size: 13px;
        color: var(--ink-faint);
      }
      .post-cover {
        margin: 8px 0 28px;
      }
      .post-cover img {
        display: block;
        width: 100%;
        height: auto;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--bone);
      }
      .post-rule {
        border: 0;
        border-top: 1px solid var(--line);
        margin: 0 0 40px;
      }
      .post-body {
        font-family: var(--body);
        font-size: 18px;
        line-height: 1.8;
        color: var(--ink-soft);
      }
      .post-body :global(p) {
        margin: 0 0 1.4em;
      }
      .post-body :global(h2) {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(26px, 2.6vw, 32px);
        line-height: 1.2;
        letter-spacing: -0.012em;
        color: var(--ink);
        margin: 2.2em 0 0.8em;
      }
      .post-body :global(h3) {
        font-family: var(--sans);
        font-weight: 600;
        font-size: 18px;
        color: var(--ink);
        margin: 1.8em 0 0.6em;
      }
      .post-body :global(a) {
        color: var(--coral);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
      }
      .post-body :global(strong) {
        color: var(--ink);
        font-weight: 600;
      }
      .post-body :global(em) {
        font-family: var(--serif);
        font-style: italic;
      }
      .post-body :global(ul),
      .post-body :global(ol) {
        padding-left: 1.4em;
        margin: 0 0 1.4em;
      }
      .post-body :global(li) {
        margin-bottom: 0.4em;
      }
      .post-body :global(blockquote) {
        border-left: 2px solid var(--coral);
        padding-left: 18px;
        margin: 1.6em 0;
        font-family: var(--serif);
        font-style: italic;
        color: var(--ink-soft);
      }
      .post-body :global(code) {
        font-family: var(--mono);
        font-size: 0.9em;
        background: var(--paper-warm);
        padding: 2px 6px;
        border-radius: 4px;
        color: var(--ink);
      }
      .post-body :global(pre) {
        background: var(--bone);
        border: 1px solid var(--line-soft);
        padding: 20px 22px;
        border-radius: 4px;
        overflow-x: auto;
        margin: 1.4em 0;
        font-family: var(--mono);
        font-size: 13px;
        line-height: 1.55;
      }
      /*
       * Astro/Shiki stamps an inline `background-color:#xxx; color:#xxx;`
       * on `.astro-code` based on the configured theme. We supply a
       * custom paper theme in `astro.config.ts`, but pin the background
       * to `--bone` here as a belt-and-braces guard against a theme
       * upgrade silently re-introducing a slate slab.
       */
      .post-body :global(pre.astro-code),
      .post-body :global(pre.shiki) {
        background-color: var(--bone) !important;
        color: var(--ink) !important;
      }
      .post-body :global(pre code) {
        background: transparent;
        padding: 0;
        font-size: inherit;
      }
      .post-body :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.4em 0;
        font-family: var(--body);
        font-size: 15px;
      }
      .post-body :global(th),
      .post-body :global(td) {
        border-bottom: 1px solid var(--line-soft);
        padding: 10px 12px;
        text-align: left;
        vertical-align: top;
      }
      .post-body :global(th) {
        font-family: var(--sans);
        font-weight: 600;
        color: var(--ink);
        border-bottom: 1px solid var(--line);
      }
      .post-body :global(hr) {
        border: 0;
        border-top: 1px solid var(--line-soft);
        margin: 2em 0;
      }

      .post-conversion {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: center;
        margin: 52px 0 40px;
        padding: 28px;
        border: 1px solid var(--line);
        background: color-mix(in srgb, var(--paper-warm) 72%, white);
      }
      .post-conversion .label {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--coral);
      }
      .post-conversion h2 {
        margin: 10px 0 8px;
        font-family: var(--serif);
        font-size: clamp(28px, 3vw, 38px);
        font-weight: 500;
        color: var(--ink);
      }
      .post-conversion p {
        margin: 0;
        max-width: 52ch;
        color: var(--ink-soft);
      }
      .post-conversion-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
      }

      .post-foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-top: 8px;
      }
      .post-foot .post-back {
        margin-bottom: 0;
      }
      .post-github {
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
        text-decoration: none;
        transition: color 160ms ease;
      }
      .post-github:hover {
        color: var(--coral);
      }
      @media (max-width: 760px) {
        .post {
          padding: 116px 0 72px;
        }
        .post-foot {
          align-items: flex-start;
          flex-direction: column;
        }
        .post-conversion {
          grid-template-columns: 1fr;
        }
        .post-conversion-actions {
          justify-content: flex-start;
        }
      }
    </style>
  </body>
</html>
