---
/*
 * Design-example "live preview" for a design-system detail page.
 *
 * Renders ORIGINAL mock artifacts (a website, a phone app, a slide, a poster)
 * themed entirely from a system's design tokens — so a visitor instantly sees
 * what the design language looks like applied. Not screenshots of any real
 * brand; generic mocks re-skinned per system.
 *
 * Theming source, in order of fidelity:
 *  1. `theme` (real tokens from design-tokens.json: --bg / --surface / --fg /
 *     --accent / fonts / radius). Used on the detail-page scenario showcase.
 *  2. Heuristic fallback from `system.palette` (darkest → ink, lightest →
 *     surface, most-saturated mid-tone → accent). Used by the compact card
 *     thumbnails, which don't load the token file.
 */
import type { SystemRecord } from '../_lib/catalog';
import type { PreviewTheme } from '../_lib/system-tokens';

type Scenario = 'web' | 'app' | 'slides' | 'poster';

interface Props {
  system: SystemRecord;
  /** Caption (localized) shown under the mock. Omitted in compact mode. */
  caption?: string;
  /** Compact card-thumbnail variant (lean markup, no caption). */
  compact?: boolean;
  /** Which themed mock to render. Compact cards always use 'web'. */
  scenario?: Scenario;
  /** Real identity tokens — preferred over the palette heuristic when present. */
  theme?: PreviewTheme | null;
}

const { system, caption, compact = false, scenario = 'web', theme = null } =
  Astro.props as Props;

const toRgb = (h: string): [number, number, number] => {
  let s = h.replace('#', '');
  if (s.length === 3) s = s.split('').map((c) => c + c).join('');
  const n = parseInt(s, 16);
  return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
};
const lum = (rgb: [number, number, number]): number =>
  0.2126 * rgb[0] + 0.7152 * rgb[1] + 0.0722 * rgb[2];
const sat = (rgb: [number, number, number]): number => {
  const mx = Math.max(...rgb);
  const mn = Math.min(...rgb);
  return mx === 0 ? 0 : (mx - mn) / mx;
};
const HEX = /^#?[0-9a-fA-F]{3}([0-9a-fA-F]{3})?$/;
const softOf = (hex: string, a = 0.12): string => {
  if (!HEX.test(hex)) return `rgba(0,0,0,${a})`;
  const [r, g, b] = toRgb(hex);
  return `rgba(${r}, ${g}, ${b}, ${a})`;
};

const FALLBACK_FONT =
  "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif";

let bg: string;
let surface: string;
let ink: string;
let muted: string;
let line: string;
let accent: string;
let accentInk: string;
let fontDisplay: string;
let fontBody: string;
let radius: string;

if (theme) {
  // Real tokens — accurate to the system's DESIGN.md.
  bg = theme.bg;
  surface = theme.surface;
  ink = theme.fg;
  muted = theme.muted;
  line = theme.border;
  accent = theme.accent;
  accentInk = theme.accentOn;
  fontDisplay = theme.fontDisplay;
  fontBody = theme.fontBody;
  radius = theme.radius;
} else {
  // Heuristic fallback from the palette.
  const swatches = (system.palette ?? [])
    .filter((h) => HEX.test(h))
    .map((h) => ({ h, rgb: toRgb(h) }));
  const byLum = [...swatches].sort((a, b) => lum(a.rgb) - lum(b.rgb));
  const darkest = byLum[0];
  const lightest = byLum[byLum.length - 1];
  const accentCand = [...swatches]
    .filter((x) => sat(x.rgb) > 0.25 && lum(x.rgb) > 40 && lum(x.rgb) < 225)
    .sort((a, b) => sat(b.rgb) - sat(a.rgb))[0];
  ink = darkest && lum(darkest.rgb) < 115 ? darkest.h : '#14110b';
  bg = lightest && lum(lightest.rgb) > 205 ? lightest.h : '#ffffff';
  accent = (accentCand ?? darkest)?.h ?? '#533afd';
  surface = bg;
  const inkRgb = toRgb(ink);
  muted = `rgba(${inkRgb[0]}, ${inkRgb[1]}, ${inkRgb[2]}, 0.55)`;
  line = `rgba(${inkRgb[0]}, ${inkRgb[1]}, ${inkRgb[2]}, 0.12)`;
  accentInk = lum(toRgb(accent)) > 150 ? '#14110b' : '#ffffff';
  fontDisplay = FALLBACK_FONT;
  fontBody = FALLBACK_FONT;
  radius = '10px';
}

const accentSoft = softOf(accent, 0.12);

const vars = [
  `--pv-bg:${bg}`,
  `--pv-surface:${surface}`,
  `--pv-ink:${ink}`,
  `--pv-muted:${muted}`,
  `--pv-line:${line}`,
  `--pv-accent:${accent}`,
  `--pv-accent-ink:${accentInk}`,
  `--pv-accent-soft:${accentSoft}`,
  `--pv-font-display:${fontDisplay}`,
  `--pv-font-body:${fontBody}`,
  `--pv-radius:${radius}`,
].join(';');

const domain = `${system.slug}.com`;
---

{compact ? (
  <div class="pv pv-compact pv-web" style={vars} role="img" aria-label={`${system.name} design system preview`}>
    <div class="pv-chrome">
      <span class="pv-dot"></span><span class="pv-dot"></span><span class="pv-dot"></span>
    </div>
    <div class="pv-screen">
      <nav class="pv-nav">
        <span class="pv-brand"><span class="pv-logo"></span>{system.name}</span>
        <span class="pv-btn pv-btn-solid">Sign up</span>
      </nav>
      <div class="pv-h1">Build something people love.</div>
      <div class="pv-cta-row">
        <span class="pv-btn pv-btn-solid">Get started</span>
        <span class="pv-btn pv-btn-ghost">Learn more</span>
      </div>
      <div class="pv-cards">
        {['', '', ''].map(() => (
          <div class="pv-card"><span class="pv-card-icon"></span><div class="pv-card-line"></div></div>
        ))}
      </div>
    </div>
  </div>
) : (
<figure class="sys-preview">
  <div class={`pv pv-${scenario}`} style={vars} role="img" aria-label={caption}>
    {scenario === 'web' && (
      <Fragment>
        <div class="pv-chrome">
          <span class="pv-dot"></span><span class="pv-dot"></span><span class="pv-dot"></span>
          <span class="pv-url">{domain}</span>
        </div>
        <div class="pv-screen">
          <nav class="pv-nav">
            <span class="pv-brand"><span class="pv-logo"></span>{system.name}</span>
            <span class="pv-links"><span>Product</span><span>Pricing</span><span>Docs</span></span>
            <span class="pv-btn pv-btn-solid">Sign up</span>
          </nav>
          <div class="pv-hero">
            <span class="pv-badge">NEW · LIVE PREVIEW</span>
            <div class="pv-h1">Build something people love.</div>
            <div class="pv-sub">A mock UI rendered with the {system.name} design tokens — straight from its DESIGN.md.</div>
            <div class="pv-cta-row">
              <span class="pv-btn pv-btn-solid">Get started</span>
              <span class="pv-btn pv-btn-ghost">Learn more</span>
            </div>
          </div>
          <div class="pv-cards">
            {['Fast', 'Secure', 'Simple'].map((t) => (
              <div class="pv-card">
                <span class="pv-card-icon"></span>
                <div class="pv-card-title">{t}</div>
                <div class="pv-card-line"></div>
                <div class="pv-card-line short"></div>
              </div>
            ))}
          </div>
        </div>
      </Fragment>
    )}

    {scenario === 'app' && (
      <div class="pv-phone-screen">
        <div class="pv-statusbar">
          <span class="pv-clock">9:41</span>
          <span class="pv-statusdots"><span></span><span></span><span></span></span>
        </div>
        <div class="pv-app-head">
          <span class="pv-app-title">{system.name}</span>
          <span class="pv-app-avatar"></span>
        </div>
        <div class="pv-app-feature">
          <span class="pv-app-feature-tag">Today</span>
          <div class="pv-app-feature-h">Make it yours.</div>
        </div>
        <div class="pv-app-list">
          {['', '', ''].map(() => (
            <div class="pv-app-item">
              <span class="pv-app-thumb"></span>
              <div class="pv-app-item-text">
                <div class="pv-card-line"></div>
                <div class="pv-card-line short"></div>
              </div>
            </div>
          ))}
        </div>
        <div class="pv-tabbar">
          <span class="pv-tab pv-tab-active"></span>
          <span class="pv-tab"></span>
          <span class="pv-tab"></span>
          <span class="pv-tab"></span>
        </div>
      </div>
    )}

    {scenario === 'slides' && (
      <div class="pv-slide-face">
        <div class="pv-slide-head">
          <span class="pv-brand"><span class="pv-logo"></span>{system.name}</span>
          <span class="pv-slide-page">01 / 12</span>
        </div>
        <div class="pv-slide-main">
          <div class="pv-slide-text">
            <span class="pv-badge">KEYNOTE</span>
            <div class="pv-slide-title">Design that ships itself.</div>
            <div class="pv-slide-sub">One DESIGN.md — every surface on-brand.</div>
            <div class="pv-cta-row">
              <span class="pv-btn pv-btn-solid">Next</span>
              <span class="pv-btn pv-btn-ghost">Agenda</span>
            </div>
          </div>
          <div class="pv-slide-visual" aria-hidden="true">
            <div class="pv-slide-chart">
              <span style="height:42%"></span>
              <span style="height:64%"></span>
              <span style="height:88%"></span>
              <span style="height:72%"></span>
            </div>
            <div class="pv-slide-chip"></div>
            <div class="pv-slide-chip short"></div>
          </div>
        </div>
      </div>
    )}

    {scenario === 'poster' && (
      <div class="pv-poster-face">
        <div class="pv-poster-top">
          <span class="pv-poster-kicker"><span class="pv-poster-tick"></span>{system.name}</span>
          <span class="pv-poster-meta">2026</span>
        </div>
        <div class="pv-poster-mid">
          <div class="pv-poster-h1">Make<br />it<br /><span class="pv-poster-accent">real.</span></div>
        </div>
        <div class="pv-poster-foot">
          <span>Open Design</span>
          <span>DESIGN.md</span>
        </div>
      </div>
    )}
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>
)}

<style>
  .sys-preview {
    margin: 0;
  }
  .sys-preview figcaption {
    margin-top: 10px;
    font-size: 13px;
    color: var(--ink-mute, #595959);
  }
  .pv {
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    background: var(--pv-bg);
    color: var(--pv-ink);
    box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.28);
    font-family: var(--pv-font-body);
  }

  /* ── Shared atoms ──────────────────────────────────────────────── */
  .pv-chrome {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 11px 14px;
    border-bottom: 1px solid var(--pv-line);
  }
  .pv-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--pv-line);
  }
  .pv-url {
    margin-left: 10px;
    padding: 3px 12px;
    border-radius: 999px;
    background: var(--pv-accent-soft);
    color: var(--pv-muted);
    font-size: 12px;
  }
  .pv-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    font-weight: 700;
    font-size: 16px;
    font-family: var(--pv-font-display);
  }
  .pv-logo {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: var(--pv-accent);
    flex: none;
  }
  .pv-btn {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: calc(var(--pv-radius) * 0.7);
    white-space: nowrap;
  }
  .pv-btn-solid { background: var(--pv-accent); color: var(--pv-accent-ink); }
  .pv-btn-ghost { border: 1px solid var(--pv-line); color: var(--pv-ink); }
  .pv-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 5px 11px;
    border-radius: 999px;
    background: var(--pv-accent-soft);
    color: var(--pv-accent);
  }
  .pv-card-line {
    height: 7px;
    border-radius: 4px;
    background: var(--pv-line);
    margin-bottom: 6px;
  }
  .pv-card-line.short { width: 65%; }

  /* ── Scenario: web (landscape) ─────────────────────────────────── */
  .pv-screen { padding: 26px 30px 30px; }
  .pv-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 34px;
  }
  .pv-links { display: flex; gap: 22px; font-size: 13px; color: var(--pv-muted); }
  .pv-hero { margin-bottom: 30px; }
  .pv-badge + .pv-h1, .pv-hero .pv-badge { margin-bottom: 16px; }
  .pv-h1 {
    font-family: var(--pv-font-display);
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 14px;
  }
  .pv-sub {
    max-width: 460px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--pv-muted);
    margin-bottom: 22px;
  }
  .pv-cta-row { display: flex; gap: 12px; }
  .pv-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .pv-card {
    border: 1px solid var(--pv-line);
    border-radius: var(--pv-radius);
    background: var(--pv-surface);
    padding: 16px;
  }
  .pv-card-icon {
    display: block;
    width: 26px;
    height: 26px;
    border-radius: calc(var(--pv-radius) * 0.6);
    background: var(--pv-accent);
    margin-bottom: 14px;
  }
  .pv-card-title {
    font-family: var(--pv-font-display);
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 9px;
  }

  /* ── Scenario: app (phone, portrait) ───────────────────────────── */
  .pv-app {
    max-width: 280px;
    margin: 0 auto;
    border-radius: 30px;
    border: 8px solid #111;
    background: var(--pv-bg);
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.4);
  }
  .pv-phone-screen {
    aspect-ratio: 9 / 19;
    display: flex;
    flex-direction: column;
    padding: 0 16px 12px;
  }
  .pv-statusbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 4px 14px;
    font-size: 12px;
    font-weight: 600;
  }
  .pv-statusdots { display: flex; gap: 4px; }
  .pv-statusdots span { width: 6px; height: 6px; border-radius: 50%; background: var(--pv-ink); opacity: 0.5; }
  .pv-app-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .pv-app-title { font-family: var(--pv-font-display); font-size: 22px; font-weight: 800; letter-spacing: -0.01em; }
  .pv-app-avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--pv-accent-soft); border: 1px solid var(--pv-line); }
  .pv-app-feature {
    background: var(--pv-accent);
    color: var(--pv-accent-ink);
    border-radius: var(--pv-radius);
    padding: 16px;
    margin-bottom: 14px;
  }
  .pv-app-feature-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; opacity: 0.85; }
  .pv-app-feature-h { font-family: var(--pv-font-display); font-size: 22px; font-weight: 800; margin-top: 8px; }
  .pv-app-list { display: flex; flex-direction: column; gap: 10px; }
  .pv-app-item {
    display: flex;
    gap: 12px;
    align-items: center;
    border: 1px solid var(--pv-line);
    border-radius: var(--pv-radius);
    background: var(--pv-surface);
    padding: 10px;
  }
  .pv-app-thumb { width: 40px; height: 40px; border-radius: calc(var(--pv-radius) * 0.7); background: var(--pv-accent-soft); flex: none; }
  .pv-app-item-text { flex: 1; }
  .pv-app-item-text .pv-card-line { margin-bottom: 7px; }
  .pv-tabbar {
    margin-top: auto;
    display: flex;
    justify-content: space-around;
    padding-top: 14px;
    border-top: 1px solid var(--pv-line);
  }
  .pv-tab { width: 22px; height: 22px; border-radius: 7px; background: var(--pv-line); }
  .pv-tab-active { background: var(--pv-accent); }

  /* ── Scenario: slides (16:9 landscape, two-zone) ───────────────── */
  .pv-slide-face {
    aspect-ratio: 16 / 9;
    background: var(--pv-surface);
    padding: 26px 34px;
    display: flex;
    flex-direction: column;
  }
  .pv-slide-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .pv-slide-page { font-size: 12px; color: var(--pv-muted); letter-spacing: 0.08em; }
  .pv-slide-main {
    flex: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 28px;
    align-items: center;
  }
  .pv-slide-text { display: flex; flex-direction: column; align-items: flex-start; gap: 14px; }
  .pv-slide-title {
    font-family: var(--pv-font-display);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.04;
  }
  .pv-slide-sub { font-size: 15px; color: var(--pv-muted); line-height: 1.5; }
  .pv-slide-text .pv-cta-row { margin-top: 4px; }
  /* Right zone: a themed "content" visual so the slide isn't half-empty. */
  .pv-slide-visual {
    align-self: stretch;
    background: var(--pv-bg);
    border: 1px solid var(--pv-line);
    border-radius: var(--pv-radius);
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 12px;
  }
  .pv-slide-chart {
    flex: 1;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    min-height: 90px;
  }
  .pv-slide-chart span {
    flex: 1;
    border-radius: 5px 5px 0 0;
    background: var(--pv-accent);
  }
  .pv-slide-chart span:nth-child(even) { background: var(--pv-accent-soft); }
  .pv-slide-chip { height: 10px; border-radius: 5px; background: var(--pv-line); }
  .pv-slide-chip.short { width: 60%; }

  /* ── Scenario: poster (portrait, accent used as highlight) ─────── */
  .pv-poster-face {
    aspect-ratio: 3 / 4;
    background: var(--pv-surface);
    color: var(--pv-ink);
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
  }
  .pv-poster-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .pv-poster-kicker { display: inline-flex; align-items: center; gap: 8px; color: var(--pv-accent); }
  .pv-poster-tick { width: 14px; height: 14px; border-radius: 4px; background: var(--pv-accent); }
  .pv-poster-meta { color: var(--pv-muted); }
  .pv-poster-mid { margin-top: auto; }
  .pv-poster-h1 {
    font-family: var(--pv-font-display);
    font-size: 58px;
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.03em;
  }
  .pv-poster-accent { color: var(--pv-accent); }
  .pv-poster-foot {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--pv-line);
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    font-weight: 600;
    color: var(--pv-muted);
  }

  /* ── Compact card-thumbnail variant (web only) ─────────────────── */
  .pv-compact { border-radius: 10px; box-shadow: none; }
  .pv-compact .pv-chrome { padding: 7px 10px; gap: 5px; }
  .pv-compact .pv-dot { width: 7px; height: 7px; }
  .pv-compact .pv-screen { padding: 14px 16px 16px; }
  .pv-compact .pv-nav { margin-bottom: 14px; }
  .pv-compact .pv-brand { font-size: 12px; gap: 6px; }
  .pv-compact .pv-logo { width: 16px; height: 16px; border-radius: 5px; }
  .pv-compact .pv-btn { font-size: 10px; padding: 5px 10px; border-radius: 6px; }
  .pv-compact .pv-h1 { font-size: 19px; margin-bottom: 12px; }
  .pv-compact .pv-cta-row { margin-bottom: 14px; }
  .pv-compact .pv-cards { gap: 8px; }
  .pv-compact .pv-card { padding: 10px; }
  .pv-compact .pv-card-icon { width: 16px; height: 16px; margin-bottom: 0; }

  @media (max-width: 640px) {
    .pv-screen { padding: 20px; }
    .pv-links { display: none; }
    .pv-h1 { font-size: 30px; }
    .pv-cards { grid-template-columns: 1fr; }
    .pv-slide-title { font-size: 28px; }
    .pv-poster-h1 { font-size: 46px; }
  }
</style>
