---
/*
 * Shared shell for every sub-page outside of `/` (Skills, Systems,
 * Craft, Templates and their detail pages).
 *
 * The homepage (`/`) intentionally does NOT use this layout — its
 * chrome (rails, topbar, full hero, mega-word footer) stays in
 * lockstep with `design-templates/open-design-landing/example.html`. This
 * layout is the lighter sibling: same Atelier Zero tokens, same
 * sticky nav, but no editorial side rails or hero, and a compact
 * footer focused on the site map.
 *
 * Every sub-page passes `title`, `description`, `active` (nav
 * highlight) and an optional `jsonLd`. Catalog counts are read from
 * `getCatalogCounts()` so the nav badges stay live.
 */
import '../globals.css';
import '../sub-pages.css';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import FaviconLinks from './favicon-links.astro';
import SiteAnalytics from './site-analytics.astro';
import ResourceHints from './resource-hints.astro';
import HeaderEnhancer from './header-enhancer.astro';
import { Header, type HeaderProps } from './header';
import LocaleSwitcherScript from './locale-switcher-script.astro';
import PreciseLazyload from './precise-lazyload.astro';
import TemplateCardAutoplay from './template-card-autoplay.astro';
import SiteFooter from './site-footer.astro';
import { ogDefaultImage } from '../image-assets';
import {
  LANDING_LOCALES,
  alternateLinksForPath,
  getHeaderLocaleSwitcher,
  getLocaleDefinition,
  localeFromPath,
} from '../i18n';
import { getCatalogCounts } from '../_lib/catalog';
import { getGithubRepoMeta } from '../_lib/github';
import { clampDescription } from '../_lib/clamp-description';

export interface Props {
  title: string;
  description: string;
  active?: HeaderProps['active'];
  ogImage?: string;
  /** Optional comma-separated meta keywords. Emitted only when provided. */
  keywords?: string;
  /**
   * Suppress the on-load locale auto-redirect for THIS page while keeping it
   * fully localized (hreflang alternates + working language switcher). Unlike
   * `localeCanonicalOnly`, the page still has per-locale variants; we just
   * don't bounce a (e.g.) zh-preference visitor off the URL they clicked.
   */
  suppressLocaleAutoRedirect?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  /**
   * Set on pages that are NOT generated per-locale (e.g. plugin detail pages,
   * which would explode the page count × 18 locales). The language switcher
   * then points every locale at the single canonical URL and the client script
   * suppresses its locale auto-redirect, so a zh-preference visitor is not sent
   * to a non-existent `/zh/...` variant that 404s.
   */
  localeCanonicalOnly?: boolean;
  /**
   * Class applied to the `<main>` wrapper. Defaults to the centered
   * `sub-main container` shell. Full-bleed pages (e.g. the community pages,
   * which draw edge-to-edge tinted section bands and center their own content
   * via an inner `.wrap`) pass just `sub-main` to opt out of `.container`'s
   * max-width + side padding.
   */
  mainClassName?: string;
}

const {
  title,
  description,
  active = 'home',
  ogImage,
  keywords,
  jsonLd,
  localeCanonicalOnly = false,
  suppressLocaleAutoRedirect = false,
  mainClassName = 'sub-main container',
} = Astro.props;
// Clamp the meta/OG/Twitter description to a search-friendly length (the full
// string still flows into JSON-LD untouched).
const metaDescription = clampDescription(description);
const locale = localeFromPath(Astro.url.pathname);
const localeDef = getLocaleDefinition(locale);
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
// Canonical-only pages have no per-locale variants, so emit only the canonical
// (x-default) hreflang — listing `/<locale>/...` alternates that 404 would feed
// search engines dangling targets. `altEntries[0]` is the default-locale
// (stripped) path, so x-default stays correct for localized pages too.
const altEntries = alternateLinksForPath(Astro.url.pathname);
const alternateLinks = localeCanonicalOnly
  ? []
  : altEntries.map((entry) => ({
      ...entry,
      href: new URL(entry.hrefPath, Astro.site).toString(),
    }));
const xDefaultHref = new URL(altEntries[0]!.hrefPath, Astro.site).toString();
// Absolute URL for the social share card: og:image / twitter:image are read
// by external crawlers outside the page-origin context, so a same-origin path
// is unreliable for rich previews. The default is the site-wide OG card
// (`ogDefaultImage`, already an absolute R2 URL); `new URL()` leaves an
// already-absolute `ogImage` override untouched.
const og = new URL(ogImage ?? ogDefaultImage, Astro.site).toString();
const counts = await getCatalogCounts();
const github = await getGithubRepoMeta();
const headerHtml = renderToStaticMarkup(
  Header({
    active,
    counts,
    github,
    brandHref: '/',
    locale,
    localeSwitcher: getHeaderLocaleSwitcher(locale, Astro.url.pathname, {
      canonicalOnly: localeCanonicalOnly,
    }),
  }) as ReturnType<typeof createElement>,
);
const ldArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html
  lang={localeDef.htmlLang}
  dir={localeDef.dir}
  data-locale-canonical={localeCanonicalOnly ? 'true' : undefined}
  data-locale-autoredirect={suppressLocaleAutoRedirect ? 'off' : undefined}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#efe7d2" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((entry) => (
      <link rel="alternate" hreflang={entry.hreflang} href={entry.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <FaviconLinks />
    <ResourceHints />

    <SiteAnalytics />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Open Design" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={og} />
    <meta property="og:locale" content={localeDef.ogLocale} />
    {LANDING_LOCALES.filter((entry) => entry.code !== locale).map((entry) => (
      <meta property="og:locale:alternate" content={entry.ogLocale} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={og} />

    {ldArray.map((data) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body class="sub-page">
    <div class="shell">
      <div class="site-chrome" data-chrome-headroom>
        {/* Same React-rendered Header used by the homepage (language switcher
         * lives in the nav, no separate topbar) so the chrome matches `/`. */}
        <Fragment set:html={headerHtml} />
      </div>

      <main class={mainClassName}>
        <slot />
      </main>

      <SiteFooter counts={counts} locale={locale} />
    </div>

    <HeaderEnhancer />
    <LocaleSwitcherScript />
    <PreciseLazyload />
    {/* Hover-autoplay + idle hold/pan loop for any TemplateCard preview clips on
        the page. Self-initialising and a no-op when the page has no cards, so it
        covers every TemplateCard consumer (templates grids, solution pages, …)
        from one place — a card that renders <video data-tpl-autoplay> is never
        left inert. */}
    <TemplateCardAutoplay />
  </body>
</html>
