---
/*
 * Shared renderer for /alternatives/<slug>/ comparison pages.
 *
 * Each route is a thin wrapper that passes `slug` (and the competitor's
 * display name for the flat-fallback table header). When the alternative
 * copy carries a `rich` payload this renders the industrial long-form
 * layout (hero CTA + warm-paper hero illustration + sectioned blocks +
 * FAQ), matching the agent detail pages; otherwise it falls back to the
 * compact comparison layout. Copy is honest about where the competitor
 * wins and carries a not-affiliated note.
 */
import Layout from './sub-page-layout.astro';
import { getInfoPageCopy, getAlternativeCopy } from '../info-page-i18n';
import { localeFromPath, localizedHref } from '../i18n';
import { downloadFirstCtas } from '../cta-actions';
import '../_partials/comparison-v4.css';

interface Props {
  slug: string;
  competitorName: string;
}
const { slug, competitorName } = Astro.props;

const SITE = Astro.site?.toString() ?? 'https://open-design.ai/';
const REPO = 'https://github.com/nexu-io/open-design';
const REPO_RELEASES = `${REPO}/releases`;
const locale = localeFromPath(Astro.url.pathname);
const href = (path: string) => localizedHref(path, locale);
const common = getInfoPageCopy(locale).common;
// en always supplies each slug, so the fallback in getAlternativeCopy
// guarantees a value here.
const page = getAlternativeCopy(locale, slug)!;
const rich = page.rich;

const title = page.title;
const description = page.description;
const features = page.features;

const ctaHref = (a: { href: string; external?: boolean }) =>
  a.external ? a.href : href(a.href);

// Comparison pages lead with the desktop download — see cta-actions.ts.
const heroCtas = rich ? downloadFirstCtas(rich.heroCtaActions) : [];
const finalCtas = rich ? downloadFirstCtas(rich.ctaActions) : [];

const faqEntries = (rich?.faq ?? page.faq).map(({ name, text }) => ({ name, text }));

const homeUrl = new URL(href('/'), SITE).toString();
const compareUrl = new URL(href('/compare/'), SITE).toString();
const pageUrl = new URL(Astro.url.pathname, SITE).toString();

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Open Design', item: homeUrl },
      { '@type': 'ListItem', position: 2, name: 'Compare', item: compareUrl },
      { '@type': 'ListItem', position: 3, name: page.breadcrumb, item: pageUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: pageUrl,
    isPartOf: { '@id': `${SITE}#website` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqEntries.map(({ name, text }) => ({
      '@type': 'Question',
      name,
      acceptedAnswer: { '@type': 'Answer', text },
    })),
  },
];
---

<Layout title={title} description={description} active="home" jsonLd={jsonLd}>
  <nav class="breadcrumb" aria-label={common.breadcrumbAria}>
    <a href={href('/')}>Open Design</a>
    <span>/</span>
    <a href={href('/compare/')}>Compare</a>
    <span>/</span>
    <span aria-current="page">{page.breadcrumb}</span>
  </nav>

  <article class={rich ? 'v4' : 'info-page'}>
    {rich ? (
      <>
        <section class="v4band v4hero">
          <div class="v4in">
            <p class="v4eye">{page.label}</p>
            <h1 class="v4h1">{page.heading}</h1>
            <p class="v4dek">{rich.heroCtaLead}</p>
            <div class="v4cta-row">
              {heroCtas.map((a) => (
                <a
                  class={a.variant === 'primary' ? 'v4btn-p' : 'v4btn-g'}
                  href={ctaHref(a)}
                  {...(a.external ? { target: '_blank', rel: 'noreferrer noopener' } : {})}
                >{a.label}</a>
              ))}
            </div>
            {rich.heroImage ? (
              <figure class="v4heroimg">
                <img src={rich.heroImage.src} alt={rich.heroImage.alt} loading="eager" decoding="async" width={1280} height={720} />
              </figure>
            ) : null}
          </div>
        </section>

        <section class="v4band alt">
          <div class="v4in">
            {rich.intro.map((p) => (<p set:html={p} />))}
            <nav class="v4toc" aria-label={rich.tocLabel}>
              {rich.toc.map((t) => (<a href={`#${t.id}`}>{t.label}</a>))}
            </nav>
          </div>
        </section>

        {rich.sections.map((section, i) => (
          <section class={`v4band${i % 2 === 1 ? ' alt' : ''}`} id={section.id}>
            <div class="v4in">
              <p class="v4eye">{String(i + 1).padStart(2, '0')}</p>
              <h2 class="v4h2">{section.heading}</h2>
              {section.blocks.map((block) => {
                if (block.kind === 'p') return <p set:html={block.text} />;
                if (block.kind === 'ul') return <ul>{block.items.map((it) => (<li set:html={it} />))}</ul>;
                if (block.kind === 'ol') return <ol>{block.items.map((it) => (<li set:html={it} />))}</ol>;
                if (block.kind === 'steps')
                  return (
                    <ul class="v4steps">
                      {block.items.map((it) => (<li><strong>{it.label}:</strong> <span set:html={it.body} /></li>))}
                    </ul>
                  );
                if (block.kind === 'code')
                  return (<pre class="agent-code"><code>{block.code}</code></pre>);
                if (block.kind === 'image')
                  return (
                    <figure class="v4heroimg">
                      <img src={block.src} alt={block.alt} loading="lazy" decoding="async" />
                      {block.caption ? <figcaption>{block.caption}</figcaption> : null}
                    </figure>
                  );
                if (block.kind === 'split')
                  return (
                    <Fragment>
                      {block.text.map((t) => (<p set:html={t} />))}
                      <figure class="v4figure">
                        <img src={block.image.src} alt={block.image.alt} loading="lazy" decoding="async" />
                        {block.image.caption ? <figcaption>{block.image.caption}</figcaption> : null}
                      </figure>
                    </Fragment>
                  );
                if (block.kind === 'table')
                  return (
                    <div class={`compare-table-wrap${block.compact ? ' compare-table-wrap--compact' : ''}`}>
                      <table class="compare-table">
                        <thead>
                          <tr>{block.columns.map((c) => (<th set:html={c} />))}</tr>
                        </thead>
                        <tbody>
                          {block.rows.map((row) => (
                            <tr>
                              {row.map((cell, ci) => (
                                ci === 0 ? <th scope="row" set:html={cell} /> : <td set:html={cell} />
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  );
                return null;
              })}
            </div>
          </section>
        ))}

        <section class="v4band alt" id="faq">
          <div class="v4in">
            <p class="v4eye">FAQ</p>
            <h2 class="v4h2">{rich.faqTitle}</h2>
            <ol class="faq-list">
              {faqEntries.map(({ name, text }, idx) => (
                <li class="faq-item">
                  <details>
                    <summary>
                      <span class="faq-index">{String(idx + 1).padStart(2, '0')}</span>
                      <span class="faq-q">{name}</span>
                      <span class="faq-toggle" aria-hidden="true">+</span>
                    </summary>
                    <p class="faq-a">{text}</p>
                  </details>
                </li>
              ))}
            </ol>
          </div>
        </section>

        <section class="v4band v4final">
          <div class="v4in">
            <h2 class="v4final-h">{rich.ctaTitle}</h2>
            <p class="v4final-p">{rich.ctaBody}</p>
            <div class="v4cta-row">
              {finalCtas.map((a) => (
                <a
                  class={a.variant === 'primary' ? 'v4btn-coral' : 'v4btn-gd'}
                  href={ctaHref(a)}
                  {...(a.external ? { target: '_blank', rel: 'noreferrer noopener' } : {})}
                >{a.label}</a>
              ))}
            </div>
            <p class="v4final-meta">● {common.apache} · {common.localFirst} · {common.byok} · <a href={href('/compare/')}>{rich.hubLinkLabel}</a></p>
          </div>
        </section>
      </>
    ) : (
      <>
        <header class="catalog-head">
          <span class="label">{page.label}</span>
          <h1 class="display">{page.heading}</h1>
          <p class="lead">{page.lead}</p>
        </header>

        <div class="tldr-card">
          <h3>{page.tldrTitle}</h3>
          <p>{page.tldrBody}</p>
        </div>

        <nav class="info-toc" aria-label={common.onThisPage}>
          <span>{common.onThisPage}</span>
          <a href="#why-search">{page.toc[0]}</a>
          <a href="#local-byok">{page.toc[1]}</a>
          <a href="#compare">{page.toc[2]}</a>
          <a href="#who">{page.toc[3]}</a>
          <a href="#migrate">{page.toc[4]}</a>
          <a href="#faq">{page.toc[5]}</a>
        </nav>

        <section class="info-section" id="why-search">
          <h2>{page.whyTitle}</h2>
          <p>{page.whyLead}</p>
          <ol>
            {page.reasons.map((item) => (
              <li><strong>{item.label}</strong> {item.body}</li>
            ))}
          </ol>
        </section>

        <section class="info-section" id="local-byok">
          <h2>{page.localByokTitle}</h2>
          {page.localByokBody.map((paragraph) => (<p>{paragraph}</p>))}
        </section>

        <section class="info-section" id="compare">
          <h2>{page.featureTitle}</h2>
          <div class="compare-table-wrap">
            <table class="compare-table">
              <thead>
                <tr><th>Feature</th><th>Open Design</th><th>{competitorName}</th></tr>
              </thead>
              <tbody>
                {features.map((f) => (
                  <tr>
                    <th scope="row">{f.name}</th>
                    <td class="yes"><span class="check">●</span>{f.od}</td>
                    <td>{f.cd}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section class="info-section" id="who">
          <h2>{page.whoTitle}</h2>
          <h3>{page.pickClaudeTitle}</h3>
          <ul>{page.pickClaude.map((item) => (<li>{item}</li>))}</ul>
          <h3>{page.pickOpenTitle}</h3>
          <ul>{page.pickOpen.map((item) => (<li>{item}</li>))}</ul>
        </section>

        <section class="info-section" id="migrate">
          <h2>{page.migrateTitle}</h2>
          <p>{page.migrateLead}</p>
          <ol>{page.migrateSteps.map((item) => (<li>{item}</li>))}</ol>
          <p>{page.migrateClosing}</p>
        </section>

        <section class="info-section" id="faq">
          <h2>{page.faqTitle}</h2>
          <ol class="faq-list">
            {faqEntries.map(({ name, text }, idx) => (
              <li class="faq-item">
                <details>
                  <summary>
                    <span class="faq-index">{String(idx + 1).padStart(2, '0')}</span>
                    <span class="faq-q">{name}</span>
                    <span class="faq-toggle" aria-hidden="true">+</span>
                  </summary>
                  <p class="faq-a">{text}</p>
                </details>
              </li>
            ))}
          </ol>
        </section>

        <section class="info-cta" aria-label="Open Design call to action">
          <div>
            <h2>{page.ctaTitle}</h2>
            <p>{page.ctaBody}</p>
          </div>
          <div class="info-cta-actions">
            <a class="btn btn-primary" href={href('/download/')}>{common.downloadDesktop}</a>
            <a class="btn btn-ghost" href={REPO} target="_blank" rel="noreferrer noopener">{common.starOnGithub}</a>
          </div>
          <div class="info-cta-meta">
            <span class="stamp">● {common.apache}</span>
            <span>{common.localFirst} · {common.byok}</span>
            <span><a class="inline-link" href={href('/compare/')}>Compare</a></span>
          </div>
        </section>
      </>
    )}
  </article>
</Layout>
